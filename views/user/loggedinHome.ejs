<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elfè Lorienveil</title>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elfé Lorienveil</title>
  <style>
    /* General Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
      
    }

 body {
  color: #615A5A;
  background: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

main {
  flex: 1;
}

    /* Navbar */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 60px;
      background: #fff;
      position: sticky;
     top: 0;
     z-index: 1000;
    }

    .navbar .logo {
      font-size: 40px;
      font-weight: 37;
      color: #B2A9A1;
    }

    .navbar ul {
      display: flex;
      list-style: none;
      gap: 25px;
      
    }

    .navbar a {
      text-decoration: none;
      color: #615A5A;
      font-size: 15px;
    }

    .navbar .btn {
      padding: 8px 15px;
      border-radius: 5px;
      background: #484848;
      color: #fff;
    }

    /* Hero */
    .hero {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    @media (max-width: 992px) {
  .hero {
    grid-template-columns: 1fr;
  }

  .hero img {
    border-radius: 0;
  }
}

    .hero img {
      width: 100%;
        border-radius: 5px;
    }

    .hero .center {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .hero h2 {
      font-size: 28px;
      font-weight: bold;
    }

    .hero h2 span {
      font-size: 40px;
    }

    .hero .btn {
      margin-top: 15px;
    }

  /* Categories */
    .categories {
      text-align: center;
      margin-top: 30px;
      padding-top: 10px;
 
    }
    @media (max-width: 992px) {
  .category-list {
    flex-wrap: wrap;
    gap: 20px;
  }

  .category {
    width: 45%;
  }
}

@media (max-width: 576px) {
  .category {
    width: 100%;
  }
}

    .categories .btn {
      margin: 15px 0;
    }

    .category-list {
      display: flex;
      justify-content: center;
      margin-top: 20px;
      
    }

    .category img {
      width: 100%;
    }

    .category p {
      margin-top: 10px;
      font-weight: bold;
      text-align: left;
       margin-bottom: 60px;
       
    }
    .category p:hover {
     text-decoration: underline;
       
    }
    /* New Arrivals */
    .new-arrivals {
      text-align: center;
      padding: 50px 60px;
    }

    .products {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
    }
   @media (max-width: 992px) {
  .products {
    flex-wrap: wrap;
    gap: 20px;
  }

  .product img {
    width: 100%;
    max-width: 260px;
  }
}
    .product img {
      width: 220px;
      border-radius: 8px;
    }

    .product h3 {
      font-size: 15px;
      margin: 10px 0 5px;
    }

    .product p {
      font-size: 13px;
      color: #555;
    }

    .product span {
      font-weight: bold;
    }

    /* Footer */
    footer {
      margin-top: 40px;
      background: #f6f6f6;
      padding: 40px 60px;
      color: #666;
    }
     .footer .logo {
      font-size: 60px;
      font-weight: 37;
      color: #B2A9A1;
    }
    .footer-top {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .footer-top h4 {
      margin-bottom: 10px;
      color: #333;
    }

    .footer-top input {
      padding: 8px;
      width: 200px;
      border: 1px solid #ccc;
      border-radius: 4px;
    }

    .footer-bottom {
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
    }
        /* Home Video Section */
.home-video {
  width: 100%;
  padding: 0;
}

.home-video video {
  width: 100%;
  
  display: block;
  pointer-events: none; /* disables interaction */
}
@media (max-width: 768px) {
  footer {
    padding: 30px 20px;
  }

  .footer-top {
    flex-direction: column;
    gap: 20px;
  }

  .footer .logo {
    font-size: 40px;
  }
}

  </style>
</head>
<body>
  <!-- Navbar -->
  <%-include('../partials/user/loggedinHeader')%>
<!-- hero section -->
  <section class="hero" style="margin-bottom: 30px; margin-left: 8px; margin-right: 8px;">
    <div class="hero-item">
      <img src="/images/IMG_9763.png" alt="Hero Image 1">
    </div>
    <div class="hero-item center" style="padding-top: 0; ">
     <img src="/images/image.png" alt="Hero Image 2">
        <a href="/products" style="opacity: 90%; border-radius: 6px; background-color: #898078;padding: 20px; margin: 20px; position: absolute; color: #ffffff; font-size: 18px; font-weight: lighter;font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">EXPLORE SHOP</a>
     </div>
    <div class="hero-item">
      <img src="/images/heroimage3.png" alt="Hero Image 3">
    </div>
  </section>
  
<!-- Auto Playing Video Section -->
<section class="home-video">
  <video 
    autoplay 
    muted 
    loop 
    playsinline 
    preload="auto"
    disablePictureInPicture
    controlslist="nodownload nofullscreen noremoteplayback"
    oncontextmenu="return false;"
  >
    <source src="/videos/home.webm" type="video/webm">
    Your browser does not support the video tag.
  </video>
</section>

  <!-- New Arrivals -->
  <section class="new-arrivals" >
    <h2>NEW ARRIVALS</h2>
    <div class="products" style="gap: 2px; text-align: left; ">
  <% if (latestProducts && latestProducts.length > 0) { %>
    <% latestProducts.forEach(function(product) { %>
      <div class="product" style="gap: 0;">
        <a href="/product/<%= product._id %>" style="text-decoration:none; color:inherit;">
          <img 
            src="<%= product.images && product.images.length > 0 ? imageUrl(product.images[0]) : '/images/product1.png' %>" 
            alt="<%= product.productName %>" style="border-radius: 0px;">
          <h3><%= product.productName %></h3>
        
          <span style=" font-weight:550; font-size: 15px;">Rs. <%= product.finalPrice ? product.finalPrice.toFixed(2) : '0.00' %></span>
        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No new arrivals available.</p>
  <% } %>
</div>
  </section>
  <!-- Explore by Category -->
  <section class="categories" style="padding-left: 10px ; padding-right: 10px ;">
    <h2>EXPLORE BY CATEGORY</h2>
     <div class="category-list"  >
  <% if (categories && categories.length > 0) { %>
    <% categories.forEach(function(cat) { %>
      <div class="category" >
        <a href="/products?category=<%= cat._id %>" style="text-decoration:none; color:inherit;">
         <img  src="<%= imageUrl(cat.image) ?   imageUrl(cat.image) : '/images/catimage1.png' %>" alt="<%= cat.name %>" >
          <p style="margin-bottom: 0; text-decoration: none;"><%= cat.name.toUpperCase() %></p>
          <p style=" margin-top: 2px; font-size: 14px; font-weight: lighter;font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">EXPLORE</p>        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No categories available</p>
  <% } %>
</div>
   
  </section>

  <!-- Footer -->
  <%-include('../partials/user/footer')%>

  <script>
    
    window.addEventListener('pageshow', function (event) {
      if (event.persisted) {
        window.location.reload();
      }
    });
  </script>
</body>
</html>
