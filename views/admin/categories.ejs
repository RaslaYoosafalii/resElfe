<script>
document.addEventListener('DOMContentLoaded', function () {

  document.querySelectorAll('.offer-form').forEach(function (form) {

    form.addEventListener('submit', function (e) {

      const valueInput = form.querySelector('input[name="offerValue"]');
      const dateInput  = form.querySelector('input[name="offerValidDate"]');

      const value = valueInput.value.trim();
      const date  = dateInput.value.trim();

      if (!value && !date) {
        e.preventDefault();

        Swal.fire({
          icon: 'error',
          title: 'Offer value and date are required',
          showConfirmButton: false,
          timer: 2000
        });
      }

    });

  });

});

 document.getElementById("addCategoryForm").addEventListener("submit", async function(e){
  e.preventDefault();

  const formData = new URLSearchParams(new FormData(this));

  const res = await fetch("/admin/category/create",{
    method:"POST",
    body:formData
  });

  if(res.ok){
    Swal.fire("Success","Category created","success");
    setTimeout(()=>loadCategories(),500);
  }else{
    Swal.fire("Error","Failed to create category","error");
  }
});
document.addEventListener("submit",async function(e){

  const form = e.target.closest(".ajax-sub-create");
  if(!form) return;

  e.preventDefault();

  const formData = new URLSearchParams(new FormData(form));

  const res = await fetch("/admin/category/subcreate",{
    method:"POST",
    body:formData
  });

  if(res.ok){
    Swal.fire("Success","Subcategory added","success");
    loadCategories();
  }else{
    Swal.fire("Error","Failed to create subcategory","error");
  }

});

document.addEventListener("click", function(e){

  const link = e.target.closest(".pagination-box a");
  if(!link) return;

  e.preventDefault();

  const url = new URL(link.href);

  const page = url.searchParams.get("page");
  const q = url.searchParams.get("q") || "";

loadCategories({
  page,
  q: currentQuery.q
});
window.history.replaceState({}, '', '/admin/category?' + new URLSearchParams(currentQuery));
});


let currentQuery = {
  page:1,
  q:""
};

async function loadCategories(params = {}) {

  currentQuery = {...currentQuery, ...params};

  const query = new URLSearchParams(currentQuery).toString();

  const res = await fetch("/admin/category?" + query, {
    headers: { "X-Requested-With": "XMLHttpRequest" }
  });

  const html = await res.text();

  const doc = new DOMParser().parseFromString(html, "text/html");

  document.querySelector(".category-table").innerHTML =
    doc.querySelector(".category-table").innerHTML;

const newPagination = doc.querySelector(".pagination-box");
const currentPagination = document.querySelector(".pagination-box");

if(newPagination){

  if(currentPagination){
    currentPagination.innerHTML = newPagination.innerHTML;
  }else{
    document.querySelector(".main-content").appendChild(newPagination);
  }

}

}
</script>

